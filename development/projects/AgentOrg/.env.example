# =============================================================================
# AgentOrg Environment Variables
# Copy to .env and fill in your values: cp .env.example .env
# =============================================================================

# --- Gateway ---
OPENCLAW_GATEWAY_TOKEN=        # Auto-generated by setup.sh
OPENCLAW_GATEWAY_PORT=18791    # Gateway API port (host)
OPENCLAW_BRIDGE_PORT=18792     # Bridge port (host)

# --- AI Model Providers ---
OPENROUTER_API_KEY=            # Primary provider — https://openrouter.ai/keys
ANTHROPIC_API_KEY=             # Optional direct Anthropic — https://console.anthropic.com/
OLLAMA_BASE_URL=               # Optional local models — http://localhost:11434

# --- Channel Tokens ---
DISCORD_BOT_TOKEN=             # Discord bot token
TELEGRAM_BOT_TOKEN=            # Telegram bot token
SLACK_BOT_TOKEN=               # Slack bot token

# --- AgentOrg Settings ---
AGENTORG_TIMEZONE=UTC          # e.g. America/New_York, Europe/London
AGENTORG_DAILY_BUDGET=5.00     # Daily API spend limit in USD
AGENTORG_FOUNDER_NAME=         # Your name (used in agent prompts)
