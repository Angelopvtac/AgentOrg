{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Knowledge Collection",
  "description": "Schema for AgentOrg knowledge graph collections (decisions, insights, lessons)",
  "type": "object",
  "required": ["collection", "description", "entries"],
  "properties": {
    "collection": {
      "type": "string",
      "enum": ["decisions", "insights", "lessons"],
      "description": "Collection identifier"
    },
    "description": {
      "type": "string",
      "description": "Purpose of this collection"
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/entry"
      }
    }
  },
  "definitions": {
    "entry": {
      "type": "object",
      "required": ["id", "timestamp", "author", "title", "content", "tags", "phase"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "Unique entry identifier"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 creation timestamp"
        },
        "author": {
          "type": "string",
          "description": "Agent ID that created the entry"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200,
          "description": "Short descriptive title"
        },
        "content": {
          "type": "string",
          "minLength": 1,
          "description": "Full entry content"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "description": "Categorization tags"
        },
        "phase": {
          "type": "string",
          "enum": ["L0", "L1", "L2", "L3", "L4", "L5", "L6"],
          "description": "Phase when entry was created"
        },
        "relatedIds": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uuid"
          },
          "default": [],
          "description": "UUIDs of related entries"
        }
      }
    }
  }
}
