{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Human Task",
  "description": "Schema for tasks that require founder action",
  "type": "object",
  "required": ["tasks", "stats"],
  "properties": {
    "tasks": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/task"
      }
    },
    "stats": {
      "type": "object",
      "required": ["totalCreated", "totalCompleted", "totalCancelled"],
      "properties": {
        "totalCreated": {
          "type": "integer",
          "minimum": 0
        },
        "totalCompleted": {
          "type": "integer",
          "minimum": 0
        },
        "totalCancelled": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  },
  "definitions": {
    "task": {
      "type": "object",
      "required": ["id", "createdBy", "title", "description", "priority", "status", "createdAt"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "Unique task identifier"
        },
        "createdBy": {
          "type": "string",
          "description": "Agent ID that created the task"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200,
          "description": "Short task title"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "description": "What needs to be done and why"
        },
        "priority": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"],
          "description": "Task priority level"
        },
        "estimatedMinutes": {
          "type": ["number", "null"],
          "minimum": 1,
          "description": "Estimated time to complete in minutes"
        },
        "deadline": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "ISO 8601 deadline"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "in-progress", "done", "cancelled"],
          "description": "Current task status"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 creation timestamp"
        },
        "completedAt": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "ISO 8601 completion timestamp"
        },
        "completionNotes": {
          "type": ["string", "null"],
          "description": "Notes about the completion"
        }
      }
    }
  }
}
