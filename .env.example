# =============================================================================
# AgentOrg Environment Variables
# Copy to .env and fill in your values: cp .env.example .env
# =============================================================================

# --- Gateway Authentication ---
# Token for authenticating API requests to the gateway.
# Auto-generated by scripts/setup.sh — do not share.
OPENCLAW_GATEWAY_TOKEN=

# --- Network Ports ---
# Host ports mapped to the gateway container.
# Change these if you have port conflicts.
OPENCLAW_GATEWAY_PORT=18791    # Gateway API (internal: 18789)
OPENCLAW_BRIDGE_PORT=18792     # Bridge API (internal: 18790)

# --- AI Model Providers ---
# At least one provider is required. OpenRouter is the primary provider.
OPENROUTER_API_KEY=            # REQUIRED — https://openrouter.ai/keys
ANTHROPIC_API_KEY=             # Optional — direct Anthropic API (https://console.anthropic.com/)
OLLAMA_BASE_URL=               # Optional — local Ollama endpoint (e.g., http://localhost:11434)

# --- Channel Tokens ---
# Fill in when you enable messaging channels in config/openclaw.json.
# Leave blank if not using the channel.
DISCORD_BOT_TOKEN=             # Discord bot token (https://discord.com/developers)
TELEGRAM_BOT_TOKEN=            # Telegram bot token (https://t.me/BotFather)
SLACK_BOT_TOKEN=               # Slack bot token (https://api.slack.com/apps)

# --- AgentOrg Settings ---
# These are used by agents during operation.
AGENTORG_TIMEZONE=UTC          # IANA timezone (e.g., America/New_York, Europe/London)
AGENTORG_DAILY_BUDGET=5.00     # Daily API spend limit in USD
AGENTORG_FOUNDER_NAME=         # Your name — used in agent prompts and greetings
